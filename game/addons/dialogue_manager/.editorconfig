# .editorconfig — isenção de código de TERCEIRO (DialogueManager addon, MIT, v3.10.4).
#
# Por que existe (F2-E.6 / ADR-003): o runtime C# do plugin (DialogueManager.cs) é
# código de terceiro que NÃO segue o style guide do GusWorld. Sob a config estrita do
# Game.csproj (TreatWarningsAsErrors=true + AnalysisLevel=latest-recommended + Nullable
# enable) ele dispara ~29 diagnósticos (CA2211/CA1711/CA1310/CA1707/CA1822/CA2201/CA1305/
# CA1805 + CS8604/CS8625 de nullability) que viram ERRO de build.
#
# Decisão de engenharia: NÃO impomos nosso style/analyzer a código de dependência nem
# patchamos o arquivo de terceiro (divergir do upstream é frágil a cada update do plugin).
# Em vez disso, isentamos a ÁRVORE do addon dos analyzers e da nullability. Nosso código
# (game/scripts/**) permanece 100% estrito.
#
# Mecanismo: este arquivo herda do .editorconfig root (root=true na raiz do repo) e, por
# ser mais específico (subpasta), sobrescreve a severidade APENAS aqui. Diagnóstico com
# severity=none não gera warning, logo TreatWarningsAsErrors não tem o que promover a erro.
#
# NÃO usar root=true aqui (manteria a herança do .editorconfig do repo desnecessária e
# duplicaria regras). Escopo restrito a *.cs desta subárvore.

[*.cs]
# Marca como código gerado/terceiro: suprime a maioria dos analyzers de estilo na origem.
generated_code = true

# Zera o catálogo inteiro de analyzers (CAxxxx, IDExxxx) para esta subárvore.
dotnet_analyzer_diagnostic.severity = none

# Nullability do COMPILADOR (CSxxxx) não é coberta por dotnet_analyzer_diagnostic;
# rebaixar explicitamente os que o runtime do plugin dispara.
dotnet_diagnostic.CS8600.severity = none   # conversão null/possível-null em non-nullable
dotnet_diagnostic.CS8601.severity = none   # possível atribuição de null (defensivo)
dotnet_diagnostic.CS8602.severity = none   # deref de possível null (defensivo)
dotnet_diagnostic.CS8603.severity = none   # possível retorno null (defensivo)
dotnet_diagnostic.CS8604.severity = none   # possível arg nulo em param non-nullable
dotnet_diagnostic.CS8618.severity = none   # field non-nullable não inicializado (defensivo)
dotnet_diagnostic.CS8625.severity = none   # literal null em tipo de referência non-nullable

# Compiler warnings de higiene que o plugin de terceiro dispara.
dotnet_diagnostic.CS0168.severity = none   # variável declarada mas nunca usada (catch e)
dotnet_diagnostic.CS0219.severity = none   # variável atribuída mas nunca usada (defensivo)

# Cobertura defensiva: regras de estilo IDE que o repo trata como warning/none no root,
# reforçadas aqui como none para o terceiro (evita ruído caso EnforceCodeStyleInBuild ligue).
dotnet_diagnostic.IDE0005.severity = none
