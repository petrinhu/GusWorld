; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GusWorld"
config/version="0.0.1"
config/description="RPG turn-based 3D estilizado. Prodígio-hacker de 11 anos contra megacorporação ciber-gótica. Solo indie."
run/main_scene=""
config/features=PackedStringArray("4.4", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

; AutoLoads desativados em F2-S.MIG.0 (engine/ virou submodule gus_dragon-engine, vazio até F2-S.MIG.1).
; Reativar quando F2-S.MIG.1 migrar event_bus.gd + localization.gd pra C# em:
;   res://engine/foundation/buses/{GameStateBus,PlayerBus,CombatBus,UIBus}.cs
;   res://engine/foundation/localization/Localization.cs
; Backup GDScript em /tmp/engine-gdscript-backup-YYYYMMDD/
; EventBus="*res://engine/event_bus/event_bus.gd"
; Localization="*res://engine/localization/localization.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[internationalization]

locale/fallback="pt_BR"

[rendering]

renderer/rendering_method="forward_plus"
